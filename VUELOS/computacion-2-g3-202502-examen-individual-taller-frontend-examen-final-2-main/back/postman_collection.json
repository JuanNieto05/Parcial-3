{
    "info": {
        "_postman_id": "vuelos-api-collection",
        "name": "Vuelos API",
        "description": "Colección de endpoints para la API de Vuelos de Aerolíneas",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"Avianca\",\n    \"password\": \"admin123\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:8080/api/v1/auth/login",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Endpoint para autenticarse y obtener un token JWT. Aerolíneas disponibles: Avianca, VivaAir"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Vuelos",
            "item": [
                {
                    "name": "Crear Vuelo",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "description": "Token JWT obtenido del login"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"numeroVuelo\": \"AV404\",\n    \"estado\": \"PROGRAMADO\",\n    \"aerolineaId\": 1\n}"
                        },
                        "url": {
                            "raw": "http://localhost:8080/api/v1/vuelos",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "vuelos"
                            ]
                        },
                        "description": "Crea un nuevo vuelo. Estados posibles: PROGRAMADO, EN_VUELO, ATERRIZADO"
                    },
                    "response": []
                },
                {
                    "name": "Actualizar Vuelo",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "description": "Token JWT obtenido del login"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"numeroVuelo\": \"AV404\",\n    \"estado\": \"ATERRIZADO\",\n    \"aerolineaId\": 1\n}"
                        },
                        "url": {
                            "raw": "http://localhost:8080/api/v1/vuelos/1",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "vuelos",
                                "1"
                            ]
                        },
                        "description": "Actualiza un vuelo existente por su ID"
                    },
                    "response": []
                },
                {
                    "name": "Obtener Todos los Vuelos",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "description": "Token JWT obtenido del login"
                            }
                        ],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/vuelos",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "vuelos"
                            ]
                        },
                        "description": "Obtiene todos los vuelos de la aerolínea autenticada"
                    },
                    "response": []
                },
                {
                    "name": "Eliminar Vuelo",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "description": "Token JWT obtenido del login"
                            }
                        ],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/vuelos/1",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "vuelos",
                                "1"
                            ]
                        },
                        "description": "Elimina un vuelo por su ID"
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ]
}